{
  "name": "docscribe-vscode",
  "displayName": "DocScribe",
  "description": "Auto-generate inline YARD documentation for Ruby methods using docscribe",
  "version": "0.1.0",
  "publisher": "unurgunite",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FlorexLabs/docscribe-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/FlorexLabs/docscribe-vscode/issues"
  },
  "homepage": "https://github.com/FlorexLabs/docscribe-vscode#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "ruby",
    "yard",
    "documentation",
    "docscribe"
  ],
  "activationEvents": [
    "onLanguage:ruby",
    "onLanguage:rake",
    "workspaceContains:**/Gemfile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "docscribe.checkFile",
        "title": "DocScribe: Check current file"
      },
      {
        "command": "docscribe.checkWorkspace",
        "title": "DocScribe: Check entire workspace"
      },
      {
        "command": "docscribe.safeFix",
        "title": "DocScribe: Apply safe fixes to current file"
      },
      {
        "command": "docscribe.aggressiveFix",
        "title": "DocScribe: Apply aggressive fixes to current file"
      },
      {
        "command": "docscribe.applyFix",
        "title": "DocScribe: Apply fix"
      },
      {
        "command": "docscribe.toggleFoldComments",
        "title": "DocScribe: Toggle fold YARD comments"
      }
    ],
    "keybindings": [
      {
        "command": "docscribe.checkFile",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorLangId == ruby"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "docscribe.checkFile",
          "when": "editorLangId == ruby",
          "group": "navigation@1"
        },
        {
          "command": "docscribe.safeFix",
          "when": "editorLangId == ruby",
          "group": "1_modification@1"
        },
        {
          "command": "docscribe.aggressiveFix",
          "when": "editorLangId == ruby",
          "group": "1_modification@2"
        }
      ]
    },
    "configuration": {
      "title": "DocScribe",
      "properties": {
        "docscribe.commandPath": {
          "type": "string",
          "default": "docscribe",
          "description": "Path to the docscribe executable"
        },
        "docscribe.useBundleExec": {
          "type": "boolean",
          "default": true,
          "description": "Use bundle exec to run docscribe"
        },
        "docscribe.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run docscribe check automatically on file save and open"
        },
        "docscribe.useRbs": {
          "type": "boolean",
          "default": true,
          "description": "Use RBS signatures for @param/@return type inference"
        },
        "docscribe.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns for files to ignore (e.g. **/vendor/**, **/spec/**)"
        },
        "docscribe.foldComments": {
          "type": "boolean",
          "default": false,
          "description": "Collapse YARD comment blocks by default when opening a file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "mocha": "^11.7.6",
    "mock-fs": "^5.5.0",
    "prettier": "^3.8.4",
    "sinon": "^22.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
